{
    "$schema": "node_modules/wrangler/config-schema.json",
    "name": "strider",
    "compatibility_date": "2026-02-11",
    "preview_urls": true,
    "workers_dev": true,
    "assets": {
        "directory": "./dist",
        "not_found_handling": "single-page-application"
    },
    "vars": {
        "SKIP_DEPENDENCY_INSTALL": "1"
    }
}
